Algoritmo sin_titulo
	//Se requiere obtener la distancia entre dos puntos en el plano cartesiano, tal y como se muestra en la figura 2.4. 
	//Realice un diagrama de flujo y pseudocµdigo que representen el algoritmo para obtener la distancia entre esos puntos
	leer x1,y1
	leer x2,y2
	X<-x2-x1
	YM<-y2-y1
	D<-rc(X*X-YM*YM)
	Imprimir  D 
FinAlgoritmo
